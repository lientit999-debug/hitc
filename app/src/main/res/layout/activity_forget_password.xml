<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="🔑"
        android:textSize="80sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="QUÊN MẬT KHẨU"
        android:textColor="#0D47A1"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Nhập email của bạn để nhận hướng dẫn khôi phục mật khẩu"
        android:textColor="#757575"
        android:textSize="14sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/edtEmailForget"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_search_shopee"
                android:hint="Địa chỉ Email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="#212121" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSendReset"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#0D47A1"
                android:text="GỬI YÊU CẦU"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:onClick="onBackPressed"
        android:text="Quay lại đăng nhập"
        android:textColor="#0D47A1"
        android:textStyle="bold" />

</LinearLayout>