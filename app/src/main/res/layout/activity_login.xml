<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ĐĂNG NHẬP"
        android:textColor="#D4AF37"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Chào mừng Bịp thủ quay trở lại"
        android:textColor="#AAAAAA" />

    <EditText
        android:id="@+id/edtEmailLogin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_input_dark"
        android:hint="Email tổ chức"
        android:inputType="textEmailAddress"
        android:paddingLeft="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666" />

    <EditText
        android:id="@+id/edtPasswordLogin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_dark"
        android:hint="Mật mã bảo mật"
        android:inputType="textPassword"
        android:paddingLeft="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666" />

    <TextView
        android:id="@+id/tvForgetPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginTop="12dp"
        android:text="Quên mật mã?"
        android:textColor="#D4AF37" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#D4AF37"
        android:text="XÁC NHẬN"
        android:textColor="#000000"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvGoRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Chưa có tài khoản? Gia nhập ngay"
        android:textColor="#AAAAAA" />

</LinearLayout>
